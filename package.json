{
  "name": "base44-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --quiet",
    "typecheck": "tsc -p ./jsconfig.json --noEmit",
    "test": "node --test tests/*.test.js",
    "security:secrets": "node scripts/scan-secrets.mjs",
    "security:audit": "npm audit --audit-level=moderate",
    "verify": "npm run lint && npm run typecheck && npm run build && npm test && npm run security:audit && npm run security:secrets",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base44/sdk": "^0.8.3",
    "lucide-react": "^0.475.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^8.1.4"
  }
}
